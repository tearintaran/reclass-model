{
  "components": {
    "schemas": {
      "AlertStateRequest": {
        "properties": {
          "state": {
            "title": "State",
            "type": "string"
          }
        },
        "required": [
          "state"
        ],
        "title": "AlertStateRequest",
        "type": "object"
      },
      "ClassifyRequest": {
        "description": "Stateless classification preview (no persistence, no sign-off).",
        "properties": {
          "evidence": {
            "$ref": "#/components/schemas/EvidenceInput"
          },
          "variant": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/VariantRef"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "title": "ClassifyRequest",
        "type": "object"
      },
      "EvidenceBundleResponse": {
        "properties": {
          "cohort_counts": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Cohort Counts"
          },
          "events": {
            "items": {
              "additionalProperties": true,
              "type": "object"
            },
            "title": "Events",
            "type": "array"
          },
          "match": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Match"
          },
          "per_provider": {
            "additionalProperties": {
              "additionalProperties": true,
              "type": "object"
            },
            "title": "Per Provider",
            "type": "object"
          },
          "provider_versions": {
            "additionalProperties": {
              "type": "string"
            },
            "title": "Provider Versions",
            "type": "object"
          },
          "source_records": {
            "items": {
              "additionalProperties": true,
              "type": "object"
            },
            "title": "Source Records",
            "type": "array"
          },
          "transcript": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Transcript"
          },
          "variant_key": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Variant Key"
          },
          "warnings": {
            "items": {
              "type": "string"
            },
            "title": "Warnings",
            "type": "array"
          }
        },
        "title": "EvidenceBundleResponse",
        "type": "object"
      },
      "EvidenceEventModel": {
        "description": "One standardized evidence event (mirrors ``engine.scoring.EvidenceEvent``).",
        "properties": {
          "acmg_criterion": {
            "title": "Acmg Criterion",
            "type": "string"
          },
          "applied_strength": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Applied Strength"
          },
          "evidence_direction": {
            "pattern": "^(pathogenic|benign|neutral)$",
            "title": "Evidence Direction",
            "type": "string"
          },
          "points": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Points"
          },
          "raw": {
            "additionalProperties": true,
            "title": "Raw",
            "type": "object"
          },
          "source": {
            "title": "Source",
            "type": "string"
          },
          "source_version": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Source Version"
          }
        },
        "required": [
          "source",
          "acmg_criterion",
          "evidence_direction"
        ],
        "title": "EvidenceEventModel",
        "type": "object"
      },
      "EvidenceInput": {
        "description": "Evidence for classify/persist/reanalysis, given one of three ways.\n\nExactly one (or none) of ``events`` / ``signals`` / ``resolve`` selects how\nevidence is obtained; an entirely empty input is allowed and yields a\nno-evidence (VUS) draft with an explicit warning rather than an error.",
        "properties": {
          "events": {
            "anyOf": [
              {
                "items": {
                  "$ref": "#/components/schemas/EvidenceEventModel"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Events"
          },
          "resolve": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/ResolveRequest"
              },
              {
                "type": "null"
              }
            ]
          },
          "signals": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Signals"
          }
        },
        "title": "EvidenceInput",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "PersistRequest": {
        "description": "Persist a classification receipt for a (tenant, optional patient, variant).",
        "properties": {
          "evidence": {
            "$ref": "#/components/schemas/EvidenceInput"
          },
          "patient_mrn": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Patient Mrn"
          },
          "variant": {
            "$ref": "#/components/schemas/VariantRef"
          }
        },
        "required": [
          "variant"
        ],
        "title": "PersistRequest",
        "type": "object"
      },
      "ProviderInfo": {
        "description": "One configured evidence provider: its registry name and source version.",
        "properties": {
          "name": {
            "title": "Name",
            "type": "string"
          },
          "version": {
            "default": "",
            "title": "Version",
            "type": "string"
          }
        },
        "required": [
          "name"
        ],
        "title": "ProviderInfo",
        "type": "object"
      },
      "ProvidersResponse": {
        "description": "The configured evidence providers, for the reviewer UI provider panel.",
        "properties": {
          "providers": {
            "items": {
              "$ref": "#/components/schemas/ProviderInfo"
            },
            "title": "Providers",
            "type": "array"
          }
        },
        "title": "ProvidersResponse",
        "type": "object"
      },
      "ReanalysisRequest": {
        "description": "Recompute a variant from current evidence; persist/alert only on change.",
        "properties": {
          "evidence": {
            "$ref": "#/components/schemas/EvidenceInput"
          },
          "patient_mrn": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Patient Mrn"
          },
          "trigger": {
            "default": "evidence",
            "title": "Trigger",
            "type": "string"
          },
          "variant": {
            "$ref": "#/components/schemas/VariantRef"
          }
        },
        "required": [
          "variant"
        ],
        "title": "ReanalysisRequest",
        "type": "object"
      },
      "ResolveRequest": {
        "description": "Resolve evidence for a variant through configured providers.",
        "properties": {
          "providers": {
            "anyOf": [
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Providers"
          },
          "variant": {
            "$ref": "#/components/schemas/VariantRef"
          }
        },
        "required": [
          "variant"
        ],
        "title": "ResolveRequest",
        "type": "object"
      },
      "SignOffRequest": {
        "description": "Credentialed human sign-off releasing a draft for clinical use.",
        "properties": {
          "credential": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Credential"
          },
          "signed_off_by": {
            "minLength": 1,
            "title": "Signed Off By",
            "type": "string"
          }
        },
        "required": [
          "signed_off_by"
        ],
        "title": "SignOffRequest",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      },
      "ValidationRunRequest": {
        "properties": {
          "benchmark": {
            "default": "synthetic_v1",
            "title": "Benchmark",
            "type": "string"
          }
        },
        "title": "ValidationRunRequest",
        "type": "object"
      },
      "VariantRef": {
        "description": "A variant identified by genomic locus and/or a ClinVar Variation ID.\n\nAt least one usable identity must be present: a complete ``(chrom, pos, ref,\nalt)`` locus and/or a ``variation_id``. An empty/partial reference is an\n*invalid variant identity* and is rejected with HTTP 422.",
        "properties": {
          "alt": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Alt"
          },
          "build": {
            "default": "GRCh38",
            "title": "Build",
            "type": "string"
          },
          "chrom": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Chrom"
          },
          "pos": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Pos"
          },
          "ref": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Ref"
          },
          "variation_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Variation Id"
          }
        },
        "title": "VariantRef",
        "type": "object"
      }
    }
  },
  "info": {
    "description": "Tenant-aware service surface over the deterministic ACMG/AMP reclassification engine. Decision support only \u2014 no result is clinically released without credentialed sign-off.",
    "title": "Variant Reclassification API",
    "version": "1.0.0"
  },
  "openapi": "3.1.0",
